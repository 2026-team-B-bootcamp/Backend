# ── 로컬 개발용 예시 값 ──────────────────────────────────────────────
# 실제 .env는 커밋하지 않는다(.gitignore). 이 파일을 복사해 .env로 쓴다.

# PostgreSQL 계정 정보 (docker-compose의 db 서비스가 이 값으로 초기화된다)
POSTGRES_USER=bootcamp
POSTGRES_PASSWORD=changeme
POSTGRES_DB=bootcamp

# pgAdmin 로그인 정보 (개발 편의용 — 프로덕션 스택에서는 제외 권장)
PGADMIN_DEFAULT_EMAIL=admin@example.com
PGADMIN_DEFAULT_PASSWORD=changeme

# ── 애플리케이션 필수값 ─────────────────────────────────────────────
# JWT 서명 키 — 반드시 32자 이상의 무작위 문자열. 미설정/기본값이면 앱이 뜨지 않는다.
# 생성: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=

# Gemini 아이스브레이커 키 (비어 있으면 stub 템플릿으로 동작). 실키는 절대 커밋 금지.
GEMINI_API_KEY=

# ── 배포 시 명시 필요(로컬은 compose가 주입, 미설정 시 코드 기본값 사용) ──
# DATABASE_URL=postgresql+asyncpg://user:pass@db-host:5432/dbname
# REDIS_URL=redis://redis-host:6379/0
