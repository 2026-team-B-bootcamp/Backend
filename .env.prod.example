# EC2 /opt/ieum/.env 템플릿. 실제 파일은 커밋하지 않는다.
#
#   cp .env.prod.example .env && chmod 600 .env && vi .env
#
# docker-compose.prod.yml이 같은 디렉터리의 .env를 자동으로 읽어 ${...}를 채운다.
# 값을 바꾸면 반영을 위해 재기동이 필요하다:
#   docker compose -f docker-compose.prod.yml up -d

# ── DB ──────────────────────────────────────────────────────────────
POSTGRES_USER=ieum
# 무작위 24자 이상. 생성: openssl rand -base64 24
POSTGRES_PASSWORD=
POSTGRES_DB=ieum

# ── 앱 시크릿 ───────────────────────────────────────────────────────
# 32자 미만이면 앱이 기동조차 하지 않는다(app/core/config.py 검증).
# 생성: python3 -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=

# Google AI Studio에서 재발급한 새 키. 비어 있으면 stub 템플릿으로 폴백한다.
GEMINI_API_KEY=

# ── 도메인 / CORS ───────────────────────────────────────────────────
# Caddy가 인증서를 발급할 주소. DuckDNS 서브도메인을 EC2 Elastic IP에 걸어둔 값.
SITE_ADDRESS=ieum.duckdns.org
# Let's Encrypt 인증서 만료·문제 알림을 받을 주소.
ACME_EMAIL=team@example.com

# 브라우저에서 API를 호출하는 프론트 출처(쉼표 구분, 스킴 포함, 끝 슬래시 없음).
# Vercel 기본 도메인은 고정 주소라 그대로 쓴다. 비우면 localhost 폴백이라
# 프로덕션에서는 반드시 채운다.
CORS_ORIGINS=https://ieum-frontend.vercel.app

# ── 배포 이미지 ─────────────────────────────────────────────────────
# CD(deploy.yml)가 배포할 때마다 이 줄을 sha-<커밋>으로 덮어쓴다.
# 손으로 롤백할 때는 여기를 직접 고쳐도 된다.
IMAGE_TAG=latest
